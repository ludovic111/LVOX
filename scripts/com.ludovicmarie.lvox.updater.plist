<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ludovicmarie.lvox.updater</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/lvox-update</string>
    </array>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/lvox-updater-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/lvox-updater-stderr.log</string>
</dict>
</plist>
